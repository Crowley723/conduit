FROM node:25-alpine@sha256:cf38e1f3c28ac9d81cdc0c51d8220320b3b618780e44ef96a39f76f7dbfef023

RUN npm install -g pnpm

RUN apk add --no-cache git make netcat-openbsd wget

RUN wget https://go.dev/dl/go1.25.1.linux-amd64.tar.gz && \
    tar -C /usr/local -xzf go1.25.1.linux-amd64.tar.gz && \
    rm go1.25.1.linux-amd64.tar.gz

ENV GOPATH=/go
ENV PATH=$GOPATH/bin:/usr/local/go/bin:$PATH

WORKDIR /app

RUN go install github.com/cespare/reflex@latest

RUN go install github.com/go-delve/delve/cmd/dlv@latest

COPY web/package.json web/pnpm-lock.yaml ./web/
COPY go.mod go.sum ./

RUN cd web && pnpm install
RUN go mod download

COPY . .

RUN cat > /usr/local/bin/start-dev.sh << 'EOF'
#!/bin/sh
set -e

echo "Starting development environment..."

echo "Waiting for Redis..."
while ! nc -z redis 6379; do
  sleep 0.1
done
echo "Redis is ready!"

echo "Starting frontend..."
cd /app/web && pnpm run dev --host 0.0.0.0 &

echo "Starting backend with hot reload..."
cd /app && reflex -r '\.go$' -s -- go run ./cmd/conduit/main.go -c config.container.yaml &

wait
EOF

RUN chmod +x /usr/local/bin/start-dev.sh

RUN cat > /usr/local/bin/start-debug.sh << 'EOF'
#!/bin/sh
set -e

echo "Starting development environment with debugger..."

echo "Waiting for Redis..."
while ! nc -z redis 6379; do
  sleep 0.1
done
echo "Redis is ready!"

echo "Starting frontend..."
cd /app/web && pnpm run dev --host 0.0.0.0 &

echo "Starting backend with debugger on port 2345..."
cd /app && reflex -r '\.go$' -s -- dlv debug --headless --listen=:2345 --api-version=2 --accept-multiclient ./cmd/conduit/main.go -- -c config.container.yaml &

# Wait for all background processes
wait
EOF

RUN chmod +x /usr/local/bin/start-debug.sh

EXPOSE 8080 5173 2345

CMD ["/app/start-dev.sh"]